# Server Configuration
PORT=5000
NODE_ENV=development

# Client Configuration
CLIENT_ORIGIN=http://localhost:3000

# Authentication
AUTH_TOKEN_SECRET=your-super-secret-key-change-this-in-production-min-32-chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database (Optional - for future MongoDB integration)
MONGODB_URI=mongodb://localhost:27017/incanto

# AI/API Keys (Optional - for AI recommendations and chat)
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
API_KEY=your-api-key

# Email Verification (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SENDER_EMAIL=noreply@incanto.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
